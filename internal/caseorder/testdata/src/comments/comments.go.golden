package comments

func comments(x int) {
	// Switch comment
	switch x {
	/**
	Multi line comment for 1
	*/
	case 1:
		/* Comment for 1 */
		println(1)
		/* End comment for 1 */
	// Outer comment for 2
	case 2:
		// Comment for 2
		println(2)
		// End comment for 2
	/*
	 * Multi line indented comment for 3
	 * This is another line
	 */
	case 3:
		println(1)
	case 5:
		return
	}
}
