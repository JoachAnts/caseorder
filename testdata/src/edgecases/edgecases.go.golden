package edgecases

func negative(x int) {
	switch x {
	case -1:
	case 0:
	case 1:
	}
}

func comments(x int) {
	switch x {
	case 1:
		/* Comment for 1 */
		println(1)
	case 2:
		// Comment for 2
		println(2)
	}
}

func defaultPlacement(x int) {
	switch x {
	case 1:
	case 2:
	default:
		println("default")
	}
}

func defaultMiddle(x int) {
	switch x {
	case 1:
	case 2:
	default:
		println("default")
	}
}
